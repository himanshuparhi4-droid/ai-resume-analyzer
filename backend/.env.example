APP_NAME=AI Resume Analyzer
API_PREFIX=/api/v1
# Local dev:
DATABASE_URL=sqlite:///./resume_analyzer.db
# Supabase production example:
# DATABASE_URL=postgresql://postgres.[project-ref]:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_BASE_URL=http://localhost:5173
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEFAULT_JOB_SOURCE=auto
REMOTIVE_BASE_URL=https://remotive.com/api/remote-jobs
THEMUSE_BASE_URL=https://www.themuse.com/api/public/jobs
THEMUSE_API_KEY=
INDIANAPI_JOBS_BASE_URL=https://jobs.indianapi.in/jobs
INDIANAPI_API_KEY=
GREENHOUSE_BASE_URL=https://boards-api.greenhouse.io/v1/boards
GREENHOUSE_BOARD_TOKENS_RAW=
LEVER_BASE_URL=https://api.lever.co/v0/postings
LEVER_COMPANY_TOKENS_RAW=
JOOBLE_BASE_URL=https://jooble.org/api
JOOBLE_API_KEY=
ARBEITNOW_BASE_URL=https://www.arbeitnow.com/api/job-board-api
ADZUNA_BASE_URL=https://api.adzuna.com/v1/api/jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
USAJOBS_BASE_URL=https://data.usajobs.gov/api/search
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
ENABLE_EMBEDDINGS=true
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
LLM_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
FETCH_LIMIT=12
JOB_CACHE_TTL_MINUTES=360
SYNC_DEFAULT_QUERIES=["python developer","data analyst","full stack developer"]
SYNC_DEFAULT_LOCATIONS=["India","Remote"]
SYNC_INTERVAL_MINUTES=360
ENABLE_INTERNAL_SCHEDULER=false
SYNC_SECRET=local-sync-secret
ENABLE_OCR=false
TESSERACT_CMD=
POPPLER_PATH=
ENABLE_PDF_REPORTS=true
LOG_LEVEL=INFO
ENVIRONMENT=development
